{
  "name": "flowix",
  "version": "1.0.0",
  "private": true,
  "description": "FLOWIX desktop POS and stock management",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\" \"npm:dev:electron\"",
    "dev:backend": "node backend/src/server.js",
    "dev:frontend": "vite --config frontend/vite.config.js",
    "dev:electron": "wait-on tcp:5173 tcp:4010 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build:web": "vite build --config frontend/vite.config.js",
    "build:electron": "npm run build:web && electron-builder",
    "build:win": "npm run build:web && electron-builder --win nsis",
    "lint": "eslint frontend/src backend/src electron --ext .js,.jsx",
    "check": "node --check backend/src/server.js && node --check electron/main.js"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "better-sqlite3": "^11.1.2",
    "cors": "^2.8.5",
    "dayjs": "^1.11.11",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^31.2.1",
    "electron-builder": "^24.13.3",
    "eslint": "^9.9.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.flowix.desktop",
    "productName": "FLOWIX",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "backend/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FLOWIX"
    }
  }
}
