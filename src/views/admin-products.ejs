<!DOCTYPE html><html lang="tr"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><link rel="stylesheet" href="/static/css/style.css"><title>Ürün Yönetimi</title></head><body><main class="container">
<h1>Ürün Yönetimi</h1>
<%- include('partials/admin-nav') %>
<h2>Yeni Ürün</h2>
<form action="/admin/products" method="post" class="form">
  <select name="categoryId"><option value="">Kategori Seç</option><% categories.forEach(c=> { %><option value="<%= c.id %>"><%= c.name %></option><% }) %></select>
  <input name="name" placeholder="Ürün adı" required>
  <input name="slug" placeholder="slug" required>
  <input name="price" type="number" step="0.01" required>
  <input name="stock" type="number" required>
  <input name="imageUrl" placeholder="Görsel URL">
  <textarea name="description" placeholder="Açıklama"></textarea>
  <label><input type="checkbox" name="isActive" checked> Aktif</label>
  <button>Ekle</button>
</form>
<h2>Mevcut Ürünler</h2>
<% products.forEach(p => { %>
  <form action="/admin/products/<%= p.id %>/update" method="post" class="card form">
    <input name="name" value="<%= p.name %>">
    <input name="slug" value="<%= p.slug %>">
    <input name="price" type="number" step="0.01" value="<%= p.price %>">
    <input name="stock" type="number" value="<%= p.stock %>">
    <input name="imageUrl" value="<%= p.image_url %>">
    <textarea name="description"><%= p.description %></textarea>
    <select name="categoryId"><option value="">Kategori Seç</option><% categories.forEach(c=> { %><option value="<%= c.id %>" <%= p.category_id===c.id?'selected':'' %>><%= c.name %></option><% }) %></select>
    <label><input type="checkbox" name="isActive" <%= p.is_active ? 'checked' : '' %>> Aktif</label>
    <div class="row">
      <button>Kaydet</button>
  </form>
      <form action="/admin/products/<%= p.id %>/delete" method="post"><button>Sil</button></form>
    </div>
<% }) %>
</main></body></html>
