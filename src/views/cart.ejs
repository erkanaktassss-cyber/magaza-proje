<%- include('partials/header') %>
<h1>Sepet</h1>
<% if (!cart.length) { %>
  <p>Sepet boş.</p>
<% } %>
<% cart.forEach(item => { %>
  <div class="card row">
    <div><strong><%= item.name %></strong> x <%= item.quantity %></div>
    <div>₺<%= item.price * item.quantity %></div>
    <form action="/cart/remove" method="post"><input type="hidden" name="productId" value="<%= item.id %>"><button>Sil</button></form>
  </div>
<% }) %>
<h3>Toplam: ₺<%= total.toFixed(2) %></h3>
<a class="btn" href="/checkout">Checkout</a>
<%- include('partials/footer') %>
