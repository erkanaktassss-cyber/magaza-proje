<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BIOLIFE</title>
  <link rel="stylesheet" href="/static/css/style.css" />
</head>
<body>
<header class="topbar">
  <a href="/" class="logo">BIOLIFE</a>
